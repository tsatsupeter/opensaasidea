{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "OpenProjectIdea",
  "description": "Developer documentation for the OpenProjectIdea API - programmatic access to AI-generated project and business ideas.",
  "logo": {
    "light": "/logo-light.svg",
    "dark": "/logo-dark.svg",
    "href": "https://openprojectidea.com"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#F97316",
    "light": "#FB923C",
    "dark": "#EA580C"
  },
  "appearance": {
    "default": "dark"
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "search": {
    "prompt": "Search docs..."
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "icon": "book-open",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "authentication",
              "modes",
              "scopes",
              "credits"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "icon": "code",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/overview"
            ]
          },
          {
            "group": "Ideas",
            "pages": [
              "api-reference/ideas/list-ideas",
              "api-reference/ideas/search-ideas",
              "api-reference/ideas/trending-ideas",
              "api-reference/ideas/get-idea"
            ]
          },
          {
            "group": "Comments",
            "pages": [
              "api-reference/comments/list-comments",
              "api-reference/comments/create-comment",
              "api-reference/comments/delete-comment"
            ]
          },
          {
            "group": "Votes",
            "pages": [
              "api-reference/votes/get-votes",
              "api-reference/votes/cast-vote",
              "api-reference/votes/remove-vote"
            ]
          },
          {
            "group": "Bookmarks",
            "pages": [
              "api-reference/bookmarks/list-bookmarks",
              "api-reference/bookmarks/add-bookmark",
              "api-reference/bookmarks/remove-bookmark"
            ]
          },
          {
            "group": "Categories & Stats",
            "pages": [
              "api-reference/categories/list-categories",
              "api-reference/stats/platform-stats"
            ]
          },
          {
            "group": "Account",
            "pages": [
              "api-reference/account/get-credits",
              "api-reference/account/get-profile",
              "api-reference/account/get-usage"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "icon": "file-text",
        "groups": [
          {
            "group": "Reference",
            "pages": [
              "reference/errors",
              "reference/rate-limits"
            ]
          }
        ]
      }
    ],
    "anchors": [
      {
        "anchor": "API Reference",
        "href": "/api-reference/overview",
        "icon": "code"
      },
      {
        "anchor": "Get API Key",
        "href": "https://openprojectidea.com/developer-api",
        "icon": "key",
        "color": {
          "light": "#F97316",
          "dark": "#FB923C"
        }
      }
    ]
  },
  "api": {
    "mdx": {
      "server": "https://openprojectidea.com/v1/api",
      "auth": {
        "method": "key",
        "name": "x-api-key"
      }
    },
    "playground": {
      "mode": "interactive"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://openprojectidea.com/developer-api"
      },
      {
        "label": "Pricing",
        "href": "https://openprojectidea.com/pricing"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://openprojectidea.com/developer-api"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view"
    ]
  },
  "footer": {
    "socials": {
      "website": "https://openprojectidea.com"
    },
    "links": [
      {
        "header": "Product",
        "items": [
          { "label": "OpenProjectIdea", "href": "https://openprojectidea.com" },
          { "label": "OpenSaaSIdea", "href": "https://opensaasidea.com" },
          { "label": "Pricing", "href": "https://openprojectidea.com/pricing" },
          { "label": "Developer API", "href": "https://openprojectidea.com/developer-api" }
        ]
      },
      {
        "header": "Developers",
        "items": [
          { "label": "API Docs", "href": "https://docs.openprojectidea.com" },
          { "label": "Authentication", "href": "https://docs.openprojectidea.com/authentication" },
          { "label": "Error Codes", "href": "https://docs.openprojectidea.com/reference/errors" }
        ]
      },
      {
        "header": "Legal",
        "items": [
          { "label": "Privacy Policy", "href": "https://openprojectidea.com/privacy" },
          { "label": "Terms of Service", "href": "https://openprojectidea.com/terms" }
        ]
      }
    ]
  },
  "variables": {
    "broad-api-url": "https://openprojectidea.com/v1/api",
    "lite-api-url": "https://opensaasidea.com/v1/api"
  }
}
